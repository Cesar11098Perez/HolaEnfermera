            "content": "<!DOCTYPE html>\r\n<html lang=\"es\">\r\n<head>\r\n  <meta charset=\"UTF-8\">\r\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n\r\n  <title>Feliz Día de la Enfermera Emely💙</title>\r\n\r\n  <!-- CSS -->\r\n  <link rel=\"stylesheet\" href=\"style.css\">\r\n  \r\n</head>\r\n\r\n<body>\r\n\r\n  <div class=\"container\">\r\n\r\n    <div class=\"badge\">\r\n      💉 12 de Mayo · Día de la Enfermera 💉\r\n    </div>\r\n\r\n    <div class=\"sparkle-line\">\r\n      ✨ 🩺 ✨ 💙 ✨ 🩺 ✨\r\n    </div>\r\n\r\n    <h1>\r\n      ¡Feliz Día,<br>\r\n      Enfermera! Emely💙\r\n    </h1>\r\n\r\n    <span class=\"subtitle-emoji\">\r\n      🩺\r\n    </span>\r\n\r\n    <!-- CARRUSEL -->\r\n\r\n    <div class=\"card\">\r\n\r\n      <div class=\"photos-title\">\r\n      \r\n      </div>\r\n\r\n      <div class=\"carousel-container\">\r\n\r\n        <div class=\"carousel\" id=\"carousel\">\r\n\r\n          <img src=\"E1.jpeg\">\r\n          <img src=\"E2.jpeg\">\r\n          <img src=\"E3.jpeg\">\r\n          <img src=\"E4.jpeg\">\r\n          <img src=\"E5.jpeg\">\r\n          <img src=\"E6.jpeg\">\r\n          <img src=\"E7.jpeg\">\r\n          <img src=\"E8.jpeg\">\r\n          <img src=\"E9.jpeg\">\r\n\r\n        </div>\r\n\r\n      </div>\r\n\r\n    </div>\r\n\r\n    <!-- MENSAJE -->\r\n\r\n    <div class=\"card\">\r\n\r\n      <p>\r\n        Feliz día de la enfermera,  Emely 💉🩺  \r\nGracias por dedicarte a cuidar gente… aunque seguramente  se te acaba la paciencia más rápido que el suero 😂.\r\n      </p>\r\n\r\n      <br>\r\n\r\n      <p>\r\n       Admiro mucho todo lo que haces, porque no cualquiera aguanta desvelos, estrés y pacientes intensos… ya con soportarme a mí tienes experiencia profesional avanzada 😌.\r\n      \r\n       <br>\r\n<br>\r\n       Ojalá hoy te consientan mucho, porque aunque a veces me den ganas de pelear contigo, también te amo un montón 💙.  \r\nSigue siendo esa enfermera increíble y esa persona desesperante que me cae demasiado bien.\r\n      </p>\r\n\r\n      <p class=\"firma\">\r\n        Con muchísimo cariño 💙\r\n      </p>\r\n\r\n    </div>\r\n\r\n  </div>\r\n\r\n  <!-- MUSICA -->\r\n\r\n  <audio id=\"audio\" autoplay loop>\r\n    <source src=\"musica.mp3\" type=\"audio/mpeg\">\r\n  </audio>\r\n\r\n  <!-- JS -->\r\n  <script src=\"script.js\"></script>\r\n\r\n</body>\r\n</html>"
